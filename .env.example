# NetSentinel AI - Environment Variables
# Copy this file to .env and adjust values for your lab.
# cp .env.example .env

# Database
DB_URL=mysql+mysqlconnector://root:YOUR_PASSWORD@localhost/network_ai_v2

# Device credentials used for SSH/Telnet access.
DEVICE_USERNAME=admin
DEVICE_PASSWORD=admin123
DEVICE_SECRET=admin123

# SNMPv1/v2c
SNMP_COMMUNITY=public

# SNMPv3. If these are set, the SNMP helper will use SNMPv3.
# SNMP_V3_USER=netsentinel
# SNMP_V3_AUTH=admin12345
# SNMP_V3_PRIV=admin12345

# Dashboard/session security
FLASK_SECRET=change-this-long-random-value-at-least-32-characters

# Optional dashboard seed credentials for first run
DASH_USER=admin
DASH_PASS=admin123
